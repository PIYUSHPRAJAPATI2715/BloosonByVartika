{
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "blooson-by-vartika.vercel.app"
        }
      ],
      "destination": "https://bloosombyvartika.in/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://bloosonbyvartika.onrender.com/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
